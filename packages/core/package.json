{
  "name": "@orqenix/core",
  "version": "0.1.0-dev",
  "description": "Orqenix core runtime: scope, config, storage, sync engine",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./scope": {
      "import": "./dist/scope/index.js",
      "types": "./dist/scope/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.js",
      "types": "./dist/storage/index.d.ts"
    },
    "./sync": {
      "import": "./dist/sync/index.js",
      "types": "./dist/sync/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "npx rimraf dist .turbo"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.0",
    "diff": "^7.0.0",
    "gray-matter": "^4.0.3",
    "isomorphic-git": "^1.27.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/diff": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
